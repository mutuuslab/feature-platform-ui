# 백엔드 환경변수 예시 — 복사해서 server/.env 로 저장 후 키만 채우세요.
#   cp .env.example .env   (Windows: copy .env.example .env)
# server/.env 는 .gitignore 로 커밋이 차단됩니다. 키를 GitHub 에 올리지 마세요.

# Anthropic API 키 (실제 Claude AI 어시스트 활성화). 없으면 /api/ai 는 503, 프런트는 Mock 으로 동작.
ANTHROPIC_API_KEY=

# 백엔드 포트 (기본 9100). 포트 8000 은 사용 금지.
PORT=9100
