# 백엔드 환경변수 예시 — 복사해서 server/.env 로 저장 후 키만 채우세요.
#   cp .env.example .env   (Windows: copy .env.example .env)
# server/.env 는 .gitignore 로 커밋이 차단됩니다. 키를 GitHub 에 올리지 마세요.

# Anthropic API 키 (실제 Claude AI 어시스트 활성화). 없으면 /api/ai 는 503, 프런트는 Mock 으로 동작.
ANTHROPIC_API_KEY=

# Unleash 연동 — 1차: OSS(자체 호스팅, github.com/Unleash/unleash). headless(운영자는 Unleash 콘솔 미사용, 이 백엔드만 Admin API로 관리).
# 자체 호스팅:  docker compose -f docker-compose.unleash.yml up -d  →  bash unleash-init.sh  (server/UNLEASH.md 참조)
# 없으면 /api/flags 는 503, 프런트는 Mock 으로 동작. (유료 Unleash도 URL/토큰만 바꾸면 동일 동작)
UNLEASH_URL=http://localhost:4242
UNLEASH_ADMIN_TOKEN=*:*.unleash-insecure-admin-api-token
UNLEASH_PROJECT=default
# 앱 env(dev/qa/prod)와 실제 Unleash 환경명이 다를 때만 매핑. 기본(미설정)은 동일명 사용(unleash-init.sh가 dev/qa/prod 생성).
# UNLEASH_ENV_MAP=dev:development,prod:production

# 백엔드 포트 (기본 9100). 포트 8000 은 사용 금지.
PORT=9100
